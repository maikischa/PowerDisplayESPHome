# ESPHome secrets for PowerDisplayESPHome — SAMPLE / TEMPLATE
#
# Copy this file to `secrets.yaml` (same folder) and fill in your real
# values. `secrets.yaml` is gitignored and must never be committed.
#
#   cp secrets.yaml.example secrets.yaml
#
# ESPHome reads these via the `!secret <key>` references in
# power-display-esphome.yaml.

# Home Assistant native API encryption key.
# 32-byte base64 key. Generate one with:
#   openssl rand -base64 32
# or use the "Add device" flow in the ESPHome dashboard, which offers one.
encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"

# Password for OTA (over-the-air) firmware updates after the first USB flash.
ota_password: "REPLACE_WITH_OTA_PASSWORD"

# Your WiFi network credentials (2.4 GHz — the ESP32 does not do 5 GHz).
wifi_ssid: "REPLACE_WITH_WIFI_SSID"
wifi_password: "REPLACE_WITH_WIFI_PASSWORD"

# Password for the fallback captive-portal hotspot the device brings up
# if it cannot join your WiFi. Must be at least 8 characters.
fallback_password: "REPLACE_WITH_FALLBACK_PASSWORD"
